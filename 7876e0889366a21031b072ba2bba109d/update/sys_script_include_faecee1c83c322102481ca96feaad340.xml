        <script><![CDATA[var MedicationUtils = Class.create();
MedicationUtils.prototype = {
    initialize: function() {
    },

	getTotalDosage : function(medicationId){
		var gr = new GlideRecord('u_medication');
		if(gr.get('number',medicationId)){
			var dosage = parseInt(gr.getValue('u_dosage'));
			var frequency = parseInt(gr.getValue('u_frequency'));
			return dosage*frequency;
		}
		return 0;
	},
    type: 'MedicationUtils'
};]]></script>

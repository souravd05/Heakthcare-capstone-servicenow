        <script><![CDATA[var  BillingUtils = Class.create();
 BillingUtils.prototype = {
    initialize: function() {
    },

	patientTotalBillingAmt : function(patientSysId){
		var gr = new GlideRecord('u_billing');
		gr.addQuery('u_patient_id',patientSysId);
		gr.query();
		var amt =0;
		while(gr.next()){
			amt=amt+parseFloat(gr.getValue('u_total_amount'));
		}
		return amt;
	},
    type: ' BillingUtils'
};]]></script>

        <script><![CDATA[var  LabTestUtils = Class.create();
 LabTestUtils.prototype = {
    initialize: function() {
    },

	getTestResults : function(testId){
		var gr = new GlideRecord('u_lab_test');
		var res = {};
		if(gr.get('number',testId)){
			res.sys_id = gr.getUniqueValue();
			res.patient = gr.getDisplayValue('u_patient_id');
			res.result = gr.getValue('u_result');
			res.test_type = gr.getDisplayValue('u_test_type');
		}
		return res;
	},

    type: ' LabTestUtils'
};]]></script>

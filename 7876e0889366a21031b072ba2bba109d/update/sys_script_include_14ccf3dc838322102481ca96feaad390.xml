        <script><![CDATA[var  InsuranceUtils = Class.create();
 InsuranceUtils.prototype = {
    initialize: function() {
    },
	getInsuranceDetailsByPatientId : function(patientId){
		var gr = new GlideRecord('u_insurance');
		gr.addQuery('u_reference_1',patientId);
		gr.query();
		var res = [];

		while(gr.next()){
			res.push({
				Insurance_Id : gr.getValue('number'),
				Provider : gr.getValue('u_provider'),
				Coverage : gr.getValue('u_coverage_datails'),

			});
		}
		return res;
	},

    type: ' InsuranceUtils'
};]]></script>

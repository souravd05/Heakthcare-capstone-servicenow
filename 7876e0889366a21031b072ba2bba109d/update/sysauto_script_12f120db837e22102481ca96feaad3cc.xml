        <script><![CDATA[var today = new GlideDate();
var mdgr = new GlideRecord('u_medication');
mdgr.addQuery('u_start_date','<=',today);
mdgr.addQuery('u_end_date','>=',today);
mdgr.query();

while(mdgr.next()){
	var patient = mdgr.u_patient_id.getRefRecord();
	if(patient){
		gs.eventQueue('medication.reminder',mdgr, patient.sys_id,patient.u_email);
	}
}]]></script>

        <script><![CDATA[var billgr = new GlideRecord('u_billing');
billgr.addQuery('u_status','pending');
billgr.query();

while(billgr.next()){
	var patient = billgr.u_patient_id.getRefRecord();
	if(patient){
		gs.eventQueue('billing.payment.reminder',billgr,patient.sys_id,patient.u_email);
	}
}]]></script>

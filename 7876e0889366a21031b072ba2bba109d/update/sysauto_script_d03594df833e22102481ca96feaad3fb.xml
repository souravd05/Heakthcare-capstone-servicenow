        <run_type>daily</run_type>
        <script><![CDATA[var now = new GlideDateTime();  //Current Time
var target = new GlideDateTime();
target.addDays(1);

var appgr = new GlideRecord('u_appointment');
appgr.addQuery('u_appointment_date','>=',now);
appgr.addQuery('u_appointment_date','<=',target);
appgr.query();

while(appgr.next()){
	var patient = appgr.u_patient_id.getRefRecord();
	if(patient){
		gs.eventQueue('appointment.reminder.24hrs',appgr,patient.sys_id,patient.u_email);
		gs.info('Reminder sent to '+ patient.u_first_name + 'for appointment scheduled on ' + appgr.u_appointment_date);
	}
}]]></script>
